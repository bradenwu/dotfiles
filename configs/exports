# Environment Variables
# This file contains environment variable exports

# General PATH additions. Keep this idempotent because both bashrc and zshrc
# may source this file repeatedly during shell reloads.
_export_path_prepend() {
    [ -n "$1" ] || return 0
    case ":$PATH:" in
        *":$1:"*) ;;
        *) PATH="$1${PATH:+:$PATH}" ;;
    esac
}

_export_path_prepend "/usr/local/bin"
_export_path_prepend "$HOME/bin"
export PATH
unset -f _export_path_prepend

