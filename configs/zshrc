# Zsh Configuration
# This file contains zsh-specific configurations

# Load the minimum path/export baseline before oh-my-zsh or tool init.
for file in ~/.{path,exports}; do
    [ -r "$file" ] && [ -f "$file" ] && source "$file";
done;
unset file

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load
ZSH_THEME="robbyrussell"

# Plugins to load
plugins=(
    git
)

# Disable auto-setting terminal title
DISABLE_AUTO_TITLE="true"

# Load oh-my-zsh
if [ -d "$ZSH" ]; then
    source $ZSH/oh-my-zsh.sh
else
    echo "Warning: oh-my-zsh not found. Please install it first."
fi

# Load user-specific files
for file in ~/.{aliases,functions,local}; do
    [ -r "$file" ] && [ -f "$file" ] && source "$file";
done;
unset file

# Custom aliases
alias zshconfig="nano ~/.zshrc"
alias zshreload="source ~/.zshrc"
alias ohmyzsh="nano ~/.oh-my-zsh"
alias pip=pip3
alias python=python3

# Load environment variables from .env — resolve dotfiles root via symlink.
if [ -L "$HOME/.zshrc" ]; then
    _dotfiles_root="$(cd "$(dirname "$(readlink "$HOME/.zshrc")")" && pwd)/.."
else
    _dotfiles_root="$HOME/dotfiles"
fi
if [ -f "$_dotfiles_root/.env" ]; then
    set -a
    source "$_dotfiles_root/.env"
    set +a
fi
unset _dotfiles_root

export HOMEBREW_NO_AUTO_UPDATE=1

# >>> portable init helpers >>>
# Usage: init_if_found "name" "source_file" "path1" "path2" ...
init_if_found() {
    local name="$1"
    local source_file="$2"
    shift 2

    for path in "$@"; do
        if [ -f "$path/$source_file" ]; then
            . "$path/$source_file"
            return 0
        fi
    done
    return 1
}

# Usage: add_to_path "path1" "path2" ... (skips non-existent, no duplicates)
add_to_path() {
    for path in "$@"; do
        if [ -d "$path" ] && [[ ":$PATH:" != *":$path:"* ]]; then
            export PATH="$path:$PATH"
        fi
    done
}
# <<< portable init helpers >>>

# bun completions + install root
export BUN_INSTALL="$HOME/.bun"
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# Tool PATHs — add_to_path skips non-existent dirs, safe on any machine.
add_to_path \
    "$HOME/.antigravity/antigravity/bin" \
    "$HOME/.opencode/bin" \
    "$HOME/.smux/bin" \
    "$BUN_INSTALL/bin"

# SCRCPY (macOS only, auto-skips if not present)
if [ -f "/Applications/极空间.app/Contents/Resources/app.asar.unpacked/bin/platform-tools/scrcpy-server" ]; then
    export SCRCPY_SERVER_PATH="/Applications/极空间.app/Contents/Resources/app.asar.unpacked/bin/platform-tools/scrcpy-server"
    add_to_path "/Applications/极空间.app/Contents/Resources/app.asar.unpacked/bin/platform-tools"
fi

# Conda — auto-detect across common install locations
if init_if_found "conda" "etc/profile.d/conda.sh" \
    "/opt/anaconda3" "/opt/miniconda3" \
    "$HOME/anaconda3" "$HOME/miniconda3" \
    "$HOME/.local/anaconda3" "$HOME/.local/miniconda3"; then
    [ -r "$HOME/.path" ] && [ -f "$HOME/.path" ] && source "$HOME/.path"
fi
